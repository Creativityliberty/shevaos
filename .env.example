# SHEVA OS - Environment Variables Template
# Copy this to your Vercel Project Settings > Environment Variables

# ------------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# ------------------------------------------------------------------------------

# Public URL of your Supabase project (from Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here

# Public Anon Key (from Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ------------------------------------------------------------------------------
# SERVER-SIDE CONFIGURATION (Private - NEVER expose in NEXT_PUBLIC_)
# ------------------------------------------------------------------------------

# Supabase Service Role Key (Required for HR, Payroll, and Admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Database URL (Optional - for direct postgres access if needed)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------

# Site URL (Use your Vercel deployment URL in production)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
